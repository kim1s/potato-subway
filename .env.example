# ── Supabase ─────────────────────────────────────────────────────────────
# Settings > Database > Connection string > Transaction pooler 탭 (앱 쿼리용)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
# Settings > Database > Connection string > Session pooler or Direct connection 탭 (마이그레이션용)
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ── 어드민 인증 ────────────────────────────────────────────────────────────
CONTENT_UPLOAD_SECRET=your-secret-here
IP_HASH_SALT=change-me

# ── Notion ────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_URL=https://www.notion.so/your-database-url
